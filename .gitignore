# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
wheels/

# Virtual environments
.venv/
venv/
ENV/
env/

# Installation artifacts
pip-log.txt
pip-delete-this-directory.txt

