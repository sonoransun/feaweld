# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini
._*

# ============================================================================
# Claude Code / AI tooling
# ============================================================================
.claude/

# ============================================================================
# FEA solver artifacts (generated at runtime)
# ============================================================================
# CalculiX
*.inp
*.frd
*.dat
*.sta
*.cvg
*.12d

# Gmsh
*.msh
*.geo_unrolled

# VTK results (generated, not source)
results/
*.vtu
*.vtk
*.pvd

# ============================================================================
# feaweld runtime cache
# ============================================================================
# Local data cache (lazy-loaded reference data)
~/.feaweld/

# Report output
*_report.html
*_comparison.html

# ============================================================================
# Dependencies / submodules — never commit upstream
# ============================================================================
# Python dependency directories
lib/
lib64/
include/
share/
bin/
pyvenv.cfg

# Git submodules and nested repos
# If any dependency is cloned locally, ignore it
.gitmodules
submodules/
vendor/
third_party/
external/

# Lock files from package managers (project uses pyproject.toml only)
Pipfile.lock
poetry.lock
pdm.lock
uv.lock

# Node (in case any JS tooling is added for dashboards)
node_modules/
package-lock.json
yarn.lock

# ============================================================================
# Large / binary files that should never be committed
# ============================================================================
*.hdf5
*.h5
*.parquet
*.feather
*.pkl
*.pickle
*.joblib
*.npy
*.npz
*.csv
*.xlsx
*.db
*.sqlite
*.sqlite3

# ML model artifacts
models/
*.onnx
*.pt
*.pth
*.h5

# Images / screenshots (generated)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.glb
*.gltf

# Compressed archives
*.zip
*.tar
*.tar.gz
*.tgz
*.bz2
*.7z
